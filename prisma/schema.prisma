generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Tenant {
  id                String               @id @default(cuid())
  tenantCode        String               @unique
  slug              String               @unique
  name              String
  plan              String               @default("Starter Tier")
  status            String               @default("Active")
  adminEmail        String
  phone             String?
  address           String?
  requireRxApproval Boolean              @default(false)
  enablePanicAlarms Boolean              @default(true)
  tagline           String?
  gstNumber         String?
  hfrNumber         String?
  printTerms        String?              @default("Terms & Conditions apply.")
  footerSignature   String?              @default("Medical Superintendent")
  description       String?
  logoInitials      String?
  primaryColor      String?              @default("#10B981")
  logoUrl           String?
  heroImage         String?
  mapUrl            String?
  metaTitle         String?
  metaDescription   String?
  faviconUrl        String?
  servicesContent   String?
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  advances          AdvanceDeposit[]
  appointments      Appointment[]
  auditLogs         AuditLog[]
  beds              Bed[]
  birthRecords      BirthRecord[]
  bloodDonations    BloodDonation[]
  bloodDonors       BloodDonor[]
  bloodIssuances    BloodIssuance[]
  bloodRequests     BloodRequest[]
  bloodStock        BloodStock[]
  branches          Branch[]
  communications    CommunicationLog[]
  sensitivities     CultureSensitivity[]
  dispensations     Dispensation[]
  expenses          Expense[]
  grievances        Grievance[]
  icuMonitoring     IcuMonitoring[]
  icuScores         IcuScore[]
  preAuths          InsurancePreAuth[]
  invoices          Invoice[]
  labRequests       LabRequest[]
  laborRecords      LaborRecord[]
  medicines         Medicine[]
  notifications     Notification[]
  organisms         Organism[]
  partographEntries PartographEntry[]
  patients          Patient[]
  records           PatientRecord[]
  prescriptions     Prescription[]
  purchaseOrders    PurchaseOrder[]
  radiologyOrders   RadiologyOrder[]
  radiologyReports  RadiologyReport[]
  shifts            Shift[]
  attendance        StaffAttendance[]
  StockAdjustment   StockAdjustment[]
  suppliers         Supplier[]
  surgeries         Surgery[]
  tpaCompanies      TpaCompany[]
  users             User[]
  wards             Ward[]
}

model User {
  id             String            @id @default(cuid())
  userId         String            @unique
  name           String
  email          String            @unique
  passwordHash   String
  role           String
  status         String            @default("Active")
  department     String?
  phone          String?
  joinDate       String?
  specialization String?
  tenantId       String?
  rfidTag        String?           @unique
  biometricId    String?           @unique
  shiftStarted   Boolean           @default(false)
  shiftId        String?
  createdAt      DateTime          @default(now())
  updatedAt      DateTime          @updatedAt
  attendance     StaffAttendance[]
  shift          Shift?            @relation(fields: [shiftId], references: [id])
  tenant         Tenant?           @relation(fields: [tenantId], references: [id])
}

model StaffAttendance {
  id        String   @id @default(cuid())
  type      String
  method    String
  timestamp DateTime @default(now())
  location  String?
  userId    String
  tenantId  String
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  user      User     @relation(fields: [userId], references: [id])
}

model Shift {
  id        String @id @default(cuid())
  name      String
  startTime String
  endTime   String
  tenantId  String
  tenant    Tenant @relation(fields: [tenantId], references: [id])
  users     User[]
}

model Patient {
  id              String             @id @default(cuid())
  patientCode     String
  firstName       String
  lastName        String
  dob             String?
  gender          String?
  phone           String?
  email           String?
  address         String?
  bloodGroup      String?
  allergies       String?
  status          String             @default("Active")
  tenantId        String
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  passwordHash    String?
  photo           String?
  advances        AdvanceDeposit[]
  appointments    Appointment[]
  bloodRequests   BloodRequest[]
  grievances      Grievance[]
  preAuths        InsurancePreAuth[]
  invoices        Invoice[]
  labRequests     LabRequest[]
  laborRecords    LaborRecord[]
  tenant          Tenant             @relation(fields: [tenantId], references: [id])
  records         PatientRecord[]
  prescriptions   Prescription[]
  radiologyOrders RadiologyOrder[]
  surgeries       Surgery[]
}

model Appointment {
  id              String           @id @default(cuid())
  apptCode        String
  patientName     String
  doctorName      String
  department      String?
  date            String
  time            String?
  type            String           @default("OPD")
  status          String           @default("Scheduled")
  paymentStatus   String           @default("Pending")
  ward            String?
  bed             String?
  admitNotes      String?
  isMLC           Boolean          @default(false)
  mlcNumber       String?
  policeStation   String?
  firNumber       String?
  mlcDetails      String?
  isLocked        Boolean          @default(false)
  tenantId        String
  patientId       String?
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  bystanderName   String?
  bystanderPhone  String?
  traumaType      String?
  triageAt        DateTime?
  triageColor     String?
  triageLevel     Int?
  triageNotes     String?
  triageVitals    String?
  patient         Patient?         @relation(fields: [patientId], references: [id])
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  icuMonitoring   IcuMonitoring[]
  icuScores       IcuScore[]
  prescriptions   Prescription[]
  radiologyOrders RadiologyOrder[]
  surgeries       Surgery[]
}

model DemoRequest {
  id           String   @id @default(cuid())
  hospitalName String
  email        String
  phone        String
  logoUrl      String?
  heroImage    String?
  status       String   @default("Pending")
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
}

model Prescription {
  id                 String             @id @default(cuid())
  rxCode             String
  chiefComplaint     String?
  diagnosis          String?
  clinicalNotes      String?
  followUpDate       String?
  doctorName         String
  patientName        String
  patientUhId        String?
  bp                 String?
  heartRate          String?
  temperature        String?
  weight             String?
  status             String             @default("Active")
  validationStatus   String             @default("Signed")
  locked             Boolean            @default(false)
  tenantId           String
  patientId          String?
  appointmentId      String?
  isIPDReferral      Boolean            @default(false)
  referralDepartment String?
  referralUrgency    String?
  createdAt          DateTime           @default(now())
  updatedAt          DateTime           @updatedAt
  appointment        Appointment?       @relation(fields: [appointmentId], references: [id])
  patient            Patient?           @relation(fields: [patientId], references: [id])
  tenant             Tenant             @relation(fields: [tenantId], references: [id])
  items              PrescriptionItem[]
}

model PrescriptionItem {
  id             String       @id @default(cuid())
  medicineName   String
  genericName    String?
  dosage         String?
  frequency      String?
  duration       String?
  quantity       Int          @default(0)
  instructions   String?
  medicineId     String?
  prescriptionId String
  createdAt      DateTime     @default(now())
  prescription   Prescription @relation(fields: [prescriptionId], references: [id])
  medicine       Medicine?    @relation(fields: [medicineId], references: [id])
}

model PatientRecord {
  id          String   @id @default(cuid())
  categoryTag String
  title       String
  date        String
  fileUrl     String
  tenantId    String
  patientId   String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  patient     Patient  @relation(fields: [patientId], references: [id])
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model Ward {
  id          String   @id @default(cuid())
  name        String
  description String?
  tenantId    String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
  floorWing   String?
  beds        Bed[]
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model Bed {
  id        String   @id @default(cuid())
  bedNumber String
  status    String   @default("Vacant")
  wardId    String
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
  ward      Ward     @relation(fields: [wardId], references: [id])

  @@unique([wardId, bedNumber])
}

model LabRequest {
  id              String               @id @default(cuid())
  trackingId      String
  patientName     String
  patientUhId     String?
  testName        String
  category        String
  status          String               @default("Pending")
  amount          Float                @default(0)
  referringDoctor String?
  collectionTime  String?
  tenantId        String
  patientId       String?
  createdAt       DateTime             @default(now())
  updatedAt       DateTime             @updatedAt
  testResults     String?
  sensitivities   CultureSensitivity[]
  patient         Patient?             @relation(fields: [patientId], references: [id])
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
}

model Medicine {
  id                String              @id @default(cuid())
  drugCode          String
  name              String
  genericName       String?
  manufacturer      String?
  category          String              @default("Tablet")
  batchNumber       String?
  expiryDate        String?
  mrp               Float               @default(0)
  costPrice         Float               @default(0)
  stock             Int                 @default(0)
  minThreshold      Int                 @default(50)
  tenantId          String
  createdAt         DateTime            @default(now())
  updatedAt         DateTime            @updatedAt
  dispensationItems DispensationItem[]
  tenant            Tenant              @relation(fields: [tenantId], references: [id])
  prescriptionItems PrescriptionItem[]
  poItems           PurchaseOrderItem[]
  stockAdjustments  StockAdjustment[]
}

model StockAdjustment {
  id              String   @id @default(cuid())
  medicineId      String
  type            String
  quantity        Int
  notes           String?
  adjustmentPrice Float    @default(0)
  tenantId        String
  createdAt       DateTime @default(now())
  tenant          Tenant   @relation(fields: [tenantId], references: [id])
  medicine        Medicine @relation(fields: [medicineId], references: [id])
}

model AdvanceDeposit {
  id            String   @id @default(cuid())
  receiptCode   String   @unique
  amount        Float
  paymentMethod String
  status        String   @default("Available")
  notes         String?
  patientId     String
  tenantId      String
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
  tenant        Tenant   @relation(fields: [tenantId], references: [id])
  patient       Patient  @relation(fields: [patientId], references: [id])
}

model Supplier {
  id             String          @id @default(cuid())
  name           String
  contactPerson  String?
  email          String?
  phone          String?
  address        String?
  gstNumber      String?
  status         String          @default("Active")
  tenantId       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  purchaseOrders PurchaseOrder[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
}

model PurchaseOrder {
  id          String              @id @default(cuid())
  poNumber    String              @unique
  status      String              @default("Draft")
  totalAmount Float               @default(0)
  notes       String?
  supplierId  String
  tenantId    String
  createdAt   DateTime            @default(now())
  updatedAt   DateTime            @updatedAt
  tenant      Tenant              @relation(fields: [tenantId], references: [id])
  supplier    Supplier            @relation(fields: [supplierId], references: [id])
  items       PurchaseOrderItem[]
}

model PurchaseOrderItem {
  id               String        @id @default(cuid())
  quantity         Int
  unitPrice        Float
  totalPrice       Float
  receivedQuantity Int           @default(0)
  purchaseOrderId  String
  medicineId       String
  createdAt        DateTime      @default(now())
  updatedAt        DateTime      @updatedAt
  medicine         Medicine      @relation(fields: [medicineId], references: [id])
  purchaseOrder    PurchaseOrder @relation(fields: [purchaseOrderId], references: [id])
}

model Dispensation {
  id           String             @id @default(cuid())
  billCode     String
  patientName  String
  patientUhId  String?
  patientId    String?
  prescribedBy String?
  discount     Float              @default(0)
  subtotal     Float              @default(0)
  totalCost    Float              @default(0)
  tax          Float              @default(0)
  netAmount    Float              @default(0)
  status       String             @default("Completed")
  tenantId     String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  tenant       Tenant             @relation(fields: [tenantId], references: [id])
  items        DispensationItem[]
}

model DispensationItem {
  id             String       @id @default(cuid())
  quantity       Int
  unitPrice      Float
  totalPrice     Float
  medicineId     String
  dispensationId String
  createdAt      DateTime     @default(now())
  dispensation   Dispensation @relation(fields: [dispensationId], references: [id])
  medicine       Medicine     @relation(fields: [medicineId], references: [id])
}

model Invoice {
  id             String      @id @default(cuid())
  invoiceCode    String
  patientName    String
  patientUhId    String?
  patientId      String?
  serviceType    String      @default("OPD Consult")
  amount         Float       @default(0)
  discount       Float       @default(0)
  tax            Float       @default(0)
  netAmount      Float       @default(0)
  paymentMethod  String      @default("Cash")
  status         String      @default("Pending")
  notes          String?
  isTpa          Boolean     @default(false)
  tpaId          String?
  tpaReference   String?
  approvedAmount Float       @default(0)
  copayAmount    Float       @default(0)
  tpaStatus      String      @default("None")
  tenantId       String
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  Patient        Patient?    @relation(fields: [patientId], references: [id])
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  tpa            TpaCompany? @relation(fields: [tpaId], references: [id])
}

model Branch {
  id           String   @id @default(cuid())
  branchCode   String
  name         String
  facilityType String   @default("Outpatient")
  city         String?
  state        String?
  address      String?
  phone        String?
  email        String?
  status       String   @default("Operational")
  beds         String?
  notes        String?
  tenantId     String
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt
  tenant       Tenant   @relation(fields: [tenantId], references: [id])
}

model Expense {
  id        String   @id @default(cuid())
  voucherId String   @unique
  date      String
  category  String
  vendor    String
  status    String   @default("Pending")
  amount    Float    @default(0)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model Reseller {
  id        String   @id @default(cuid())
  name      String
  contact   String
  email     String
  hospitals Int      @default(0)
  revShare  String   @default("20%")
  status    String   @default("Active")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model PlatformSetting {
  id        String   @id @default(cuid())
  data      String
  updatedAt DateTime @updatedAt
}

model SystemLog {
  id          String   @id @default(cuid())
  title       String
  description String
  type        String   @default("info")
  createdAt   DateTime @default(now())
}

model SubscriptionPlan {
  id          String   @id @default(cuid())
  planCode    String   @unique
  name        String
  price       String
  maxUsers    String
  maxBranches String
  features    String
  status      String   @default("active")
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt
}

model SupportTicket {
  id        String   @id @default(cuid())
  ticketId  String   @unique
  hospital  String
  issue     String
  priority  String   @default("Medium")
  status    String   @default("open")
  reply     String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Grievance {
  id          String    @id @default(cuid())
  ticketId    String    @unique
  subject     String
  description String
  category    String
  priority    String    @default("Normal")
  status      String    @default("Open")
  patientName String
  patientId   String?
  adminReply  String?
  resolvedAt  DateTime?
  tenantId    String
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  tenant      Tenant    @relation(fields: [tenantId], references: [id])
  patient     Patient?  @relation(fields: [patientId], references: [id])
}

model Notification {
  id        String   @id @default(cuid())
  text      String
  type      String   @default("info")
  category  String   @default("System")
  isRead    Boolean  @default(false)
  tenantId  String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  tenant    Tenant   @relation(fields: [tenantId], references: [id])
}

model CommunicationLog {
  id             String   @id @default(cuid())
  recipientName  String
  recipientPhone String?
  recipientEmail String?
  channel        String
  type           String
  message        String
  status         String   @default("Pending")
  providerId     String?
  tenantId       String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt
  tenant         Tenant   @relation(fields: [tenantId], references: [id])
}

model AuditLog {
  id          String   @id @default(cuid())
  action      String
  resource    String
  resourceId  String?
  description String?
  oldValue    String?
  newValue    String?
  userId      String?
  userName    String?
  userRole    String?
  ipAddress   String?
  userAgent   String?
  tenantId    String
  createdAt   DateTime @default(now())
  tenant      Tenant   @relation(fields: [tenantId], references: [id])
}

model IcuMonitoring {
  id            String      @id @default(cuid())
  appointmentId String
  recordedAt    DateTime    @default(now())
  recordedBy    String?
  heartRate     Int?
  systolicBP    Int?
  diastolicBP   Int?
  spo2          Int?
  temp          Float?
  respRate      Int?
  isVentilated  Boolean     @default(false)
  ventMode      String?
  fiO2          Float?
  peep          Float?
  tidalVolume   Int?
  pip           Float?
  intakeTotal   Float?
  outputTotal   Float?
  balance       Float?
  infusions     String?
  tenantId      String
  createdAt     DateTime    @default(now())
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
}

model IcuScore {
  id            String      @id @default(cuid())
  appointmentId String
  scoreType     String
  scoreValue    Int
  parameters    String?
  recordedAt    DateTime    @default(now())
  tenantId      String
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  appointment   Appointment @relation(fields: [appointmentId], references: [id])
}

model Surgery {
  id              String            @id @default(cuid())
  surgeryCode     String            @unique
  patientId       String
  appointmentId   String?
  procedureName   String
  otRoom          String?
  surgeonName     String
  assistantNames  String?
  anesthetistName String?
  scrubNurseName  String?
  startTime       DateTime?
  endTime         DateTime?
  status          String            @default("Scheduled")
  anesthesiaType  String?
  preOpDiagnosis  String?
  postOpDiagnosis String?
  findings        String?
  bloodLoss       Float?
  isMlc           Boolean           @default(false)
  tenantId        String
  createdAt       DateTime          @default(now())
  updatedAt       DateTime          @updatedAt
  anesthesia      AnesthesiaRecord?
  tenant          Tenant            @relation(fields: [tenantId], references: [id])
  appointment     Appointment?      @relation(fields: [appointmentId], references: [id])
  patient         Patient           @relation(fields: [patientId], references: [id])
  checklist       SurgeryChecklist?
}

model SurgeryChecklist {
  id                       String   @id @default(cuid())
  surgeryId                String   @unique
  patientConfirmed         Boolean  @default(false)
  siteMarked               Boolean  @default(false)
  anaesthesiaSafety        Boolean  @default(false)
  pulseOximeter            Boolean  @default(false)
  allergyKnown             Boolean  @default(false)
  difficultAirway          Boolean  @default(false)
  bloodLossRisk            Boolean  @default(false)
  teamIntroduced           Boolean  @default(false)
  patientIdentityConfirmed Boolean  @default(false)
  surgicalSiteConfirmed    Boolean  @default(false)
  antibioticProphylaxis    Boolean  @default(false)
  anticipateCritical       Boolean  @default(false)
  imagingDisplayed         Boolean  @default(false)
  countsCorrect            Boolean  @default(false)
  specimenLabeled          Boolean  @default(false)
  equipmentFixed           Boolean  @default(false)
  recoveryPlan             Boolean  @default(false)
  createdAt                DateTime @default(now())
  surgery                  Surgery  @relation(fields: [surgeryId], references: [id])
}

model AnesthesiaRecord {
  id              String   @id @default(cuid())
  surgeryId       String   @unique
  preMedication   String?
  inductionAgents String?
  maintenance     String?
  reversalAgents  String?
  intubationNotes String?
  observations    String?
  createdAt       DateTime @default(now())
  surgery         Surgery  @relation(fields: [surgeryId], references: [id])
}

model BloodStock {
  id         String         @id @default(cuid())
  bloodGroup String
  component  String         @default("Whole Blood")
  units      Int            @default(0)
  expiryDate DateTime
  source     String         @default("External Donation")
  status     String         @default("Available")
  donationId String?        @unique
  tenantId   String
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt
  tenant     Tenant         @relation(fields: [tenantId], references: [id])
  donation   BloodDonation? @relation(fields: [donationId], references: [id])
}

model BloodRequest {
  id            String         @id @default(cuid())
  requestCode   String         @unique
  patientId     String
  bloodGroup    String
  component     String
  unitsRequired Int
  priority      String         @default("Routine")
  status        String         @default("Pending")
  indication    String?
  issuedAt      DateTime?
  issuedBy      String?
  tenantId      String
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt
  issuance      BloodIssuance?
  tenant        Tenant         @relation(fields: [tenantId], references: [id])
  patient       Patient        @relation(fields: [patientId], references: [id])
}

model BloodDonor {
  id             String          @id @default(cuid())
  donorCode      String          @unique
  firstName      String
  lastName       String
  gender         String
  dob            String?
  bloodGroup     String
  phone          String?
  email          String?
  address        String?
  lastDonationAt DateTime?
  status         String          @default("Active")
  tenantId       String
  createdAt      DateTime        @default(now())
  updatedAt      DateTime        @updatedAt
  donations      BloodDonation[]
  tenant         Tenant          @relation(fields: [tenantId], references: [id])
}

model BloodDonation {
  id                String      @id @default(cuid())
  donationCode      String      @unique
  donorId           String
  collectionDate    DateTime    @default(now())
  bloodGroup        String
  unitsCollected    Int         @default(1)
  hivStatus         String?     @default("Pending")
  hbvStatus         String?     @default("Pending")
  hcvStatus         String?     @default("Pending")
  syphilisStatus    String?     @default("Pending")
  malariaStatus     String?     @default("Pending")
  haemoglobin       Float?
  weight            Float?
  bp                String?
  pulse             Int?
  temp              Float?
  fitForDonation    Boolean     @default(true)
  remarks           String?
  certificateIssued Boolean     @default(false)
  tenantId          String
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt
  tenant            Tenant      @relation(fields: [tenantId], references: [id])
  donor             BloodDonor  @relation(fields: [donorId], references: [id])
  stock             BloodStock?
}

model BloodIssuance {
  id              String        @id @default(cuid())
  issuanceCode    String        @unique
  requestId       String?       @unique
  type            String        @default("Internal")
  destination     String?
  issuedBy        String
  receivedBy      String?
  issuedAt        DateTime      @default(now())
  units           Int
  bloodGroup      String
  component       String
  crossMatchNotes String?
  tenantId        String
  createdAt       DateTime      @default(now())
  tenant          Tenant        @relation(fields: [tenantId], references: [id])
  request         BloodRequest? @relation(fields: [requestId], references: [id])
}

model TpaCompany {
  id           String             @id @default(cuid())
  name         String
  contactEmail String?
  contactPhone String?
  discountRate Float              @default(0)
  status       String             @default("Active")
  tenantId     String
  createdAt    DateTime           @default(now())
  updatedAt    DateTime           @updatedAt
  preAuths     InsurancePreAuth[]
  invoices     Invoice[]
  tenant       Tenant             @relation(fields: [tenantId], references: [id])
}

model InsurancePreAuth {
  id              String     @id @default(cuid())
  patientId       String
  tpaId           String
  authCode        String?
  requestedAmount Float
  approvedAmount  Float?
  status          String     @default("Pending")
  expiryDate      DateTime?
  documentUrl     String?
  notes           String?
  tenantId        String
  createdAt       DateTime   @default(now())
  updatedAt       DateTime   @updatedAt
  tenant          Tenant     @relation(fields: [tenantId], references: [id])
  tpa             TpaCompany @relation(fields: [tpaId], references: [id])
  patient         Patient    @relation(fields: [patientId], references: [id])
}

model RadiologyOrder {
  id              String           @id @default(cuid())
  orderCode       String           @unique
  patientId       String
  modality        String
  procedureName   String
  clinicalHistory String?
  priority        String           @default("Routine")
  status          String           @default("Pending")
  appointmentId   String?
  tenantId        String
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt
  tenant          Tenant           @relation(fields: [tenantId], references: [id])
  appointment     Appointment?     @relation(fields: [appointmentId], references: [id])
  patient         Patient          @relation(fields: [patientId], references: [id])
  report          RadiologyReport?
}

model RadiologyReport {
  id              String         @id @default(cuid())
  orderId         String         @unique
  findings        String?
  impression      String?
  criticalAlert   Boolean        @default(false)
  radiologistName String?
  status          String         @default("Draft")
  dicomLink       String?
  tenantId        String
  finalizedAt     DateTime?
  createdAt       DateTime       @default(now())
  updatedAt       DateTime       @updatedAt
  tenant          Tenant         @relation(fields: [tenantId], references: [id])
  order           RadiologyOrder @relation(fields: [orderId], references: [id])
}

model LaborRecord {
  id            String            @id @default(cuid())
  patientId     String
  admissionDate DateTime          @default(now())
  edd           DateTime?
  gravida       Int?
  para          Int?
  living        Int?
  abortion      Int?
  status        String            @default("In-Labor")
  deliveryType  String?
  deliveryDate  DateTime?
  tenantId      String
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt
  births        BirthRecord[]
  tenant        Tenant            @relation(fields: [tenantId], references: [id])
  patient       Patient           @relation(fields: [patientId], references: [id])
  partograph    PartographEntry[]
}

model PartographEntry {
  id             String      @id @default(cuid())
  laborRecordId  String
  timestamp      DateTime    @default(now())
  dilation       Float?
  descent        Int?
  contractions   Int?
  fetalHeartRate Int?
  maternalPulse  Int?
  bpSys          Int?
  bpDia          Int?
  notes          String?
  tenantId       String
  createdAt      DateTime    @default(now())
  tenant         Tenant      @relation(fields: [tenantId], references: [id])
  laborRecord    LaborRecord @relation(fields: [laborRecordId], references: [id])
}

model BirthRecord {
  id            String      @id @default(cuid())
  laborRecordId String
  birthTime     DateTime    @default(now())
  gender        String
  weight        Float?
  apgar1m       Int?
  apgar5m       Int?
  babyPatientId String?     @unique
  tenantId      String
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt
  tenant        Tenant      @relation(fields: [tenantId], references: [id])
  laborRecord   LaborRecord @relation(fields: [laborRecordId], references: [id])
}

model Organism {
  id              String               @id @default(cuid())
  name            String
  category        String
  commonInfection String?
  tenantId        String
  sensitivities   CultureSensitivity[]
  tenant          Tenant               @relation(fields: [tenantId], references: [id])
}

model CultureSensitivity {
  id           String     @id @default(cuid())
  labRequestId String
  organismId   String
  antibiotic   String
  result       String
  micValue     String?
  recordedAt   DateTime   @default(now())
  tenantId     String
  tenant       Tenant     @relation(fields: [tenantId], references: [id])
  organism     Organism   @relation(fields: [organismId], references: [id])
  labRequest   LabRequest @relation(fields: [labRequestId], references: [id])
}
